<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sly.noah.core.modules.rbac.dao.RbacResourceDao">

    <resultMap id="BaseResultMap" type="com.sly.noah.core.modules.rbac.entity.RbacResource">
        <result column="id" jdbcType="INTEGER" property="id" />
        <result column="pid" jdbcType="INTEGER" property="pid" />
        <result column="name" jdbcType="VARCHAR" property="name" />
        <result column="uri" jdbcType="VARCHAR" property="uri" />
        <result column="type" jdbcType="VARCHAR" property="type" />
        <result column="rank" jdbcType="VARCHAR" property="rank" />
        <result column="description" jdbcType="VARCHAR" property="description" />
        <result column="create_time" jdbcType="TIMESTAMP" property="createTime" />
        <result column="last_update_time" jdbcType="TIMESTAMP" property="lastUpdateTime" />
    </resultMap>

    <select id="count" resultType="int">
        select count(1) from  rbac_resource
    </select>

    <select id="getById" resultMap="BaseResultMap" parameterType="integer">
        select * from rbac_resource where id = #{id}
    </select>

    <select id="getAll" resultMap="BaseResultMap" parameterType="integer">
        select * from rbac_resource order by rank asc
    </select>

    <select id="getByQueryBean" parameterType="com.sly.noah.core.modules.rbac.query_bean.RbacResourceQueryBean" resultMap="BaseResultMap">
        select * from rbac_resource where 1 = 1
        <if test="id != id">
            and id=#{id}
        </if>
        <if test="pid != null">
            and pid=#{pid}
        </if>
        <if test="type != null">
            and type=#{type}
        </if>

    </select>

    <insert id="add" parameterType="com.sly.noah.core.modules.rbac.entity.RbacResource">
        insert into rbac_resource( pid, name, uri, type, rank, description, create_time, last_update_time)
         values
        (#{pid}, #{name}, #{uri}, #{type}, #{rank}, #{description}, #{createTime}, #{lastUpdateTime})
    </insert>

    <delete id="delete" parameterType="integer">
        delete from rbac_resource where id = #{id}
    </delete>

</mapper>
