<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sly.noah.core.modules.rbac.dao.RbacRoleDao">

    <resultMap id="BaseResultMap" type="com.sly.noah.core.modules.rbac.dao.RbacRoleDao">
        <result column="id" jdbcType="INTEGER" property="id" />
        <result column="code" jdbcType="VARCHAR" property="code" />
        <result column="name" jdbcType="VARCHAR" property="name" />
        <result column="description" jdbcType="VARCHAR" property="description" />
        <result column="create_time" jdbcType="TIMESTAMP" property="createTime" />
        <result column="last_update_time" jdbcType="TIMESTAMP" property="lastUpdateTime" />
    </resultMap>

    <select id="count" resultType="int">
        select count(1) from  rbac_role
    </select>

    <select id="getById" resultMap="BaseResultMap" parameterType="integer">
        select * from rbac_role where id = #{id}
    </select>

    <select id="getAll" resultMap="BaseResultMap" parameterType="integer">
        select * from rbac_role order by code asc
    </select>

    <select id="getByQueryBean" parameterType="com.sly.noah.core.modules.rbac.query_bean.RbacRoleQueryBean" resultMap="BaseResultMap">
        select * from rbac_role where 1 = 1
        <if test="id != id">
            and id=#{id}
        </if>
        <if test="code != null">
            and code=#{code}
        </if>
        <if test="name != null">
            and name=#{name}
        </if>

    </select>

    <insert id="add" parameterType="com.sly.noah.core.modules.rbac.entity.RbacRole">
        insert into rbac_resource(code, name, description, create_time, last_update_time)
         values
        (#{code}, #{name}, #{description}, #{createTime}, #{lastUpdateTime})
    </insert>

    <delete id="delete" parameterType="integer">
        delete from rbac_role where id = #{id}
    </delete>

</mapper>
